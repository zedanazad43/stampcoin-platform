# === Server Configuration ===
NODE_ENV=development
PORT=8080

# === API Security ===
# Generate a strong token: openssl rand -base64 32
SYNC_TOKEN=your-secure-token-here

# === CORS Configuration ===
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000,http://127.0.0.1:8080

# === Blockchain/Token Configuration ===
# STP Contract address on BNB Smart Chain (mainnet deployment)
STP_CONTRACT_ADDRESS=0x1234567890123456789012345678901234567890
STC_NFT_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
WEB3_CHAIN_ID=0xaa36a7
WEB3_NETWORK=sepolia
WEB3_RPC_URL=https://rpc.sepolia.org
WEB3_EXPLORER=https://sepolia.etherscan.io

# Web3 deployment signer (DO NOT commit real values)
DEPLOYER_PRIVATE_KEY=
TREASURY_ADDRESS=
STAMP_NFT_MINT_FEE_WEI=10000000000000000

# === Database (for future use) ===
# DATABASE_URL=postgresql://user:password@localhost:5432/stampcoin

# === OAuth (Optional - for future integration) ===
# GITHUB_OAUTH_ID=
# GITHUB_OAUTH_SECRET=
# GOOGLE_OAUTH_ID=
# GOOGLE_OAUTH_SECRET=

# === Payment Integration (Optional - for future use) ===
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_test_...

# === Analytics (Optional) ===
# SENTRY_DSN=

# === Deployment URLs ===
# For Fly.io
# FLY_APP_URL=https://stampcoin-platform.fly.dev

# For Render
# RENDER_DEPLOYMENT_ID=

# === Logging ===
LOG_LEVEL=info

# === Feature Flags ===
ENABLE_WALLET_FEATURE=true
ENABLE_MARKET_FEATURE=true
ENABLE_BLOCKCHAIN_FEATURE=true
